#!/bin/bash
# cc-cockpit — v1 MVP (single-binary dispatch)
#
# Subcommands:
#   open                   — detect workspace.json, init state, launch Zellij
#   spawn --repo X --task  — create new pane running Claude in repo X
#   hook <EventName>       — internal: read stdin payload, append event
#   --version              — print version

set -u
VERSION="0.1.0-mvp"

# Resolve install root (dir containing reduce-state.sh, dashboard.sh, layouts/).
# Follows symlinks so ~/.local/bin/cc-cockpit -> ~/cc-cockpit-dev/.cc-cockpit/bin/cc-cockpit works.
__bin_real="$(readlink -f "${BASH_SOURCE[0]}")"
CC_COCKPIT_INSTALL_HOME="$(dirname "$(dirname "$__bin_real")")"

die() { echo "cc-cockpit: $*" >&2; exit 2; }

# ---------- workspace discovery ----------
find_workspace() {
  local d="$PWD"
  while [ "$d" != "/" ]; do
    if [ -f "$d/.cc-cockpit/workspace.json" ]; then
      echo "$d"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

# ---------- shared: append event under flock ----------
# $1 = event JSON (without seq / wall_clock_iso8601).
#
# Seq-gap note: the counter is bumped BEFORE the log append. If the log write
# fails (ENOSPC, ENOENT during race, etc.) the counter is permanently ahead
# and a gap in seq values is left. The reducer tolerates gaps (sort_by keeps
# order regardless), so this is a silent event-loss failure mode rather than
# a corruption one. A future hardening could use a single transactional write
# (event carries its own seq; counter updates from the event tail). v0.1: OK.
append_event() {
  local ev="$1"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || return 0
  mkdir -p "$COCKPIT_STATE_HOME"
  local lock="$COCKPIT_STATE_HOME/events.lock"
  local counter="$COCKPIT_STATE_HOME/seq.counter"
  local log="$COCKPIT_STATE_HOME/events.jsonl"
  (
    flock -x 9
    local seq=$(( $(cat "$counter" 2>/dev/null || echo 0) + 1 ))
    echo "$seq" > "$counter"
    local ts
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c \
      --argjson seq "$seq" \
      --arg ts "$ts" \
      '. + {seq: $seq, wall_clock_iso8601: $ts}' \
      <<< "$ev" >> "$log"
  ) 9>"$lock"
}

# ============================================================
# cmd: open
# ============================================================
cmd_open() {
  local ws
  ws="$(find_workspace)" || die "Not in a cc-cockpit workspace. Expected .cc-cockpit/workspace.json up the directory tree."

  # Canonicalize workspace root — state binds to this exact path.
  local ws_canonical
  ws_canonical="$(realpath -- "$ws")" || die "cannot canonicalize workspace path: $ws"

  local name
  name="$(jq -r '.name' "$ws/.cc-cockpit/workspace.json")"
  [ -n "$name" ] && [ "$name" != "null" ] || die "workspace.json missing 'name'"

  # Validate name as a safe slug — no path components, no traversal, must start alnum.
  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    die "invalid workspace name '$name' — must match ^[a-zA-Z0-9][a-zA-Z0-9._-]*\$ (no slashes, no '..')"
  fi

  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}/cc-cockpit/$name"
  mkdir -p "$state_home" \
    || die "cannot create state dir '$state_home' (permission denied or parent not writable)"
  [ -w "$state_home" ] \
    || die "state dir '$state_home' is not writable"

  # Sanity-check the install tree — if cc-cockpit was copied (not symlinked)
  # onto PATH without its siblings, CC_COCKPIT_INSTALL_HOME resolves to a dir
  # missing reduce-state.sh et al., and the dashboard would fail with an
  # unhelpful 'no such file' later. Fail loud and early.
  for f in reduce-state.sh render.sh dashboard.sh layouts/initial.kdl; do
    [ -e "$CC_COCKPIT_INSTALL_HOME/$f" ] \
      || die "broken install: missing '$CC_COCKPIT_INSTALL_HOME/$f'. Symlink the binary from a full source tree instead of copying it."
  done

  # Bind name ↔ canonical root under an init lock. The check-and-write of
  # workspace_root, seq.counter, and events.jsonl must be atomic — otherwise two
  # unrelated directories with the same 'name' opening concurrently could both
  # observe "no binding" and initialize the same state dir.
  {
    flock -x 200
    if [ -f "$state_home/workspace_root" ]; then
      local persisted
      persisted="$(cat "$state_home/workspace_root")"
      if [ "$persisted" != "$ws_canonical" ]; then
        die "workspace name '$name' is already bound to '$persisted' (current is '$ws_canonical').
    Rename the workspace (change 'name' in .cc-cockpit/workspace.json) or remove the stale
    state dir: rm -rf '$state_home'"
      fi
    else
      echo "$ws_canonical" > "$state_home/workspace_root"
    fi
    [ -f "$state_home/seq.counter" ] || echo 0 > "$state_home/seq.counter"
    [ -f "$state_home/events.jsonl" ] || touch "$state_home/events.jsonl"
  } 200>"$state_home/init.lock"

  command -v zellij >/dev/null || die "zellij not found on PATH"

  # Live-instance lock. Per design, only one cockpit may run against a workspace
  # at a time — concurrent cockpits would race on current.json.tmp, last_bell_seq,
  # and events.snapshot.jsonl. We take a non-blocking exclusive flock on fd 201
  # and hold it through `exec zellij`: bash does not set FD_CLOEXEC on
  # redirect-opened fds, so the lock persists until the zellij process exits.
  #
  # PID hint lives in a SEPARATE file (cockpit.live.pid), written only after the
  # lock is acquired. A would-be second caller reads that file BEFORE opening the
  # lockfile so the PID hint survives even though opening the lockfile truncates.
  local pid_file="$state_home/cockpit.live.pid"
  local lock_file="$state_home/cockpit.live.lock"
  local existing_holder=""
  [ -s "$pid_file" ] && existing_holder=" (pid $(cat "$pid_file" 2>/dev/null || echo ?))"

  exec 201>"$lock_file"
  if ! flock -n -x 201; then
    die "a cockpit is already running for workspace '$name'$existing_holder.
    Lockfile: $lock_file
    If you believe the holder is gone (stale lock): rm -f '$lock_file' '$pid_file'"
  fi
  # Record the eventual zellij PID. ($$ doesn't change through exec.)
  echo "$$" > "$pid_file"

  export CC_COCKPIT_HOME="$CC_COCKPIT_INSTALL_HOME"
  export COCKPIT_STATE_HOME="$state_home"
  export COCKPIT_WORKSPACE_NAME="$name"
  export CC_COCKPIT_WORKSPACE_ROOT="$ws_canonical"

  echo "cc-cockpit: workspace=$name  state=$state_home  home=$CC_COCKPIT_HOME"
  exec zellij --layout "$CC_COCKPIT_HOME/layouts/initial.kdl"
}

# ============================================================
# cmd: spawn
# ============================================================
cmd_spawn() {
  local repo="" task="" related=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo|--task|--related)
        local flag="$1"
        if [ $# -lt 2 ] || [[ "$2" == --* ]]; then
          die "spawn: $flag requires a value"
        fi
        case "$flag" in
          --repo)    repo="$2" ;;
          --task)    task="$2" ;;
          --related) related="$2" ;;
        esac
        shift 2
        ;;
      *) die "spawn: unknown flag '$1'" ;;
    esac
  done
  [ -n "$repo" ] || die "spawn: --repo required"
  [ -n "$task" ] || die "spawn: --task required"
  [ -n "${ZELLIJ:-}" ] || die "spawn: must be run inside a Zellij session (launched by 'cc-cockpit open')"
  [ -n "${CC_COCKPIT_HOME:-}" ] || die "spawn: CC_COCKPIT_HOME not set — run 'cc-cockpit open' first"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || die "spawn: COCKPIT_STATE_HOME not set"
  [ -n "${CC_COCKPIT_WORKSPACE_ROOT:-}" ] || die "spawn: CC_COCKPIT_WORKSPACE_ROOT not set"

  local ws_json="$CC_COCKPIT_WORKSPACE_ROOT/.cc-cockpit/workspace.json"
  # Validate shape before indexing — a malformed .repos would error out of
  # jq with a confusing message.
  jq -e '.repos | type == "object"' "$ws_json" >/dev/null 2>&1 \
    || die "spawn: workspace.json .repos must be an object { \"<label>\": \"<path>\", ... }"
  local rel
  rel="$(jq -r --arg k "$repo" '.repos[$k] // empty' "$ws_json")"
  if [ -z "$rel" ]; then
    local valid
    valid="$(jq -r '.repos | keys | join(", ")' "$ws_json")"
    die "spawn: unknown repo '$repo'. Valid: $valid"
  fi

  # Resolve + enforce containment. workspace.json values may be ../foo, absolute paths, or
  # symlinks — we canonicalize and require strict descendant of the canonical workspace root.
  local ws_root abs
  ws_root="$(realpath -- "$CC_COCKPIT_WORKSPACE_ROOT")" || die "spawn: cannot canonicalize workspace root"
  abs="$(realpath -m -- "$CC_COCKPIT_WORKSPACE_ROOT/$rel")"
  case "$abs/" in
    "$ws_root"/?*/) : ;;
    *) die "spawn: repo '$repo' resolves outside workspace root.
    resolved: $abs
    workspace: $ws_root" ;;
  esac
  [ -d "$abs" ] || die "spawn: repo dir does not exist: $abs"

  # Enforce "child repo is a real git repo" invariant.
  if ! git -C "$abs" rev-parse --git-dir >/dev/null 2>&1; then
    die "spawn: '$abs' is not a git repo. cc-cockpit only spawns in real child repos (run 'git init' there if you meant to)."
  fi

  command -v claude >/dev/null || die "spawn: 'claude' not found on PATH"

  local pane_name="${repo}: ${task}"
  # Truncate pane name to something reasonable
  pane_name="${pane_name:0:60}"

  zellij action new-pane --direction right --cwd "$abs" --name "$pane_name" -- \
    env \
      COCKPIT_SESSION_ACTIVE=1 \
      COCKPIT_STATE_HOME="$COCKPIT_STATE_HOME" \
      CC_COCKPIT_HOME="$CC_COCKPIT_HOME" \
      COCKPIT_WORKSPACE_NAME="$COCKPIT_WORKSPACE_NAME" \
      COCKPIT_PRIMARY_REPO="$repo" \
      COCKPIT_DECLARED_RELATED_REPOS="$related" \
      COCKPIT_TASK_NAME="$task" \
      claude
}

# ============================================================
# cmd: mark-ended (operator utility — dismiss stale sessions)
# ============================================================
cmd_mark_ended() {
  local prefix="" yes_flag=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y) yes_flag=1; shift ;;
      -*) die "mark-ended: unknown flag '$1'" ;;
      *)
        [ -z "$prefix" ] || die "mark-ended: only one positional argument expected"
        prefix="$1"; shift ;;
    esac
  done
  [ -n "$prefix" ] || die "mark-ended: need <session_id-prefix> (or 'all-non-ended') [--yes]"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || die "mark-ended: COCKPIT_STATE_HOME not set (run inside 'cc-cockpit open')"

  local log="$COCKPIT_STATE_HOME/events.jsonl"
  [ -f "$log" ] || die "no events.jsonl in $COCKPIT_STATE_HOME"

  # Collect session_ids whose latest status is not ended
  local current="$COCKPIT_STATE_HOME/current.json"
  [ -f "$current" ] || die "no current.json yet (wait for dashboard tick)"

  local targets
  if [ "$prefix" = "all-non-ended" ]; then
    targets="$(jq -r '.sessions | to_entries[] | select(.value.status != "ended") | .key' "$current")"
  else
    targets="$(jq -r --arg p "$prefix" \
      '.sessions | to_entries[] | select(.value.status != "ended" and (.key | startswith($p))) | .key' \
      "$current")"
  fi

  if [ -z "$targets" ]; then
    echo "mark-ended: no matching non-ended sessions for '$prefix'"
    return 0
  fi

  local count
  count="$(printf '%s\n' "$targets" | grep -c . || true)"

  # Defensive: require --yes when dismissing more than one session, since
  # mark-ended acts on a possibly-stale snapshot. A synthetic SessionEnd is
  # revivable (any later event from the live session will un-dismiss), but
  # noisy confirmation is still cheaper than silent batch-kill.
  if [ "$count" -gt 1 ] && [ "$yes_flag" -ne 1 ]; then
    echo "mark-ended: would dismiss $count session(s):" >&2
    while IFS= read -r sid; do [ -n "$sid" ] && printf '  - %s\n' "$sid" >&2; done <<< "$targets"
    die "re-run with --yes to confirm (or give a more specific prefix)"
  fi

  local dismissed=0
  while IFS= read -r sid; do
    [ -n "$sid" ] || continue
    local ev
    ev="$(jq -n --arg sid "$sid" --arg et "SessionEnd" \
      '{event_type:$et, session_id:$sid, payload:{synthetic:true, reason:"operator-dismissed"}}')"
    append_event "$ev"
    echo "  dismissed: $sid"
    dismissed=$((dismissed+1))
  done <<< "$targets"
  echo "mark-ended: $dismissed session(s) dismissed (any later event from a live session will un-dismiss)."
}

# ============================================================
# cmd: hook
# ============================================================
cmd_hook() {
  local event="${1:-}"
  [ -n "$event" ] || exit 0

  # Guard: silent no-op outside a cockpit-spawned session
  [ "${COCKPIT_SESSION_ACTIVE:-}" = "1" ] || exit 0
  [ -n "${COCKPIT_STATE_HOME:-}" ] || exit 0
  mkdir -p "$COCKPIT_STATE_HOME" 2>/dev/null || exit 0

  # Hooks must be silent on the Claude Code side: any stderr from jq lands in
  # the claude pane as noise. Every jq call here redirects stderr; any failure
  # causes an exit 0 (silent no-op), protecting the operator from a malformed
  # payload turning the pane into an error stream.
  local payload sid
  payload="$(cat)"
  sid="$(jq -r '.session_id // empty' <<< "$payload" 2>/dev/null)"
  [ -n "$sid" ] || exit 0

  local ev=''
  case "$event" in
    SessionStart)
      ev="$(jq -n 2>/dev/null \
        --arg sid "$sid" \
        --arg et  "SessionStart" \
        --arg repo "${COCKPIT_PRIMARY_REPO:-}" \
        --arg related "${COCKPIT_DECLARED_RELATED_REPOS:-}" \
        --arg task "${COCKPIT_TASK_NAME:-}" \
        --arg pane "${ZELLIJ_PANE_ID:-}" \
        --argjson payload "$payload" \
        '{
          event_type: $et,
          session_id: $sid,
          payload: {
            primary_repo: $repo,
            declared_related_repos: ($related | split(",") | map(select(length>0))),
            task_name: $task,
            cwd: ($payload.cwd // null),
            zellij_pane_id: (if $pane=="" then null else $pane end),
            source: ($payload.source // null),
            model: ($payload.model // null)
          }
        }')"
      ;;
    UserPromptSubmit)
      local preview
      preview="$(jq -r '.prompt // ""' <<< "$payload" 2>/dev/null | tr '\n' ' ' | cut -c1-80)"
      ev="$(jq -n 2>/dev/null \
        --arg sid "$sid" --arg et "UserPromptSubmit" --arg p "$preview" \
        '{event_type:$et, session_id:$sid, payload:{prompt_preview:$p}}')"
      ;;
    PermissionRequest)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "PermissionRequest" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    Notification)
      local ntype
      ntype="$(jq -r '.notification_type // ""' <<< "$payload" 2>/dev/null)"
      # Only admit idle_prompt / permission_prompt — these genuinely require operator attention
      case "$ntype" in
        idle_prompt|permission_prompt) ;;
        *) exit 0 ;;
      esac
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "Notification" --arg nt "$ntype" \
        '{event_type:$et, session_id:$sid, payload:{notification_type:$nt}}')"
      ;;
    PostToolUse)
      local tool
      tool="$(jq -r '.tool_name // ""' <<< "$payload" 2>/dev/null)"
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "PostToolUse" --arg t "$tool" \
        '{event_type:$et, session_id:$sid, payload:{tool_name:$t, success:true}}')"
      ;;
    Stop)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "Stop" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    SessionEnd)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "SessionEnd" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    *) exit 0 ;;
  esac

  # If jq failed to produce an event (empty), silently drop this hook
  [ -n "$ev" ] || exit 0
  append_event "$ev" 2>/dev/null || exit 0
}

# ============================================================
# dispatch
# ============================================================
case "${1:-}" in
  --version|-v) echo "cc-cockpit $VERSION" ;;
  open)         shift; cmd_open "$@" ;;
  spawn)        shift; cmd_spawn "$@" ;;
  mark-ended)   shift; cmd_mark_ended "$@" ;;
  hook)         shift; cmd_hook "$@" ;;
  help|--help|"") cat <<EOF
cc-cockpit $VERSION

Usage:
  cc-cockpit open
      Detect .cc-cockpit/workspace.json up from cwd, init state, launch Zellij.

  cc-cockpit spawn --repo <key> --task "<text>" [--related A,B]
      (run from a Zellij pane inside 'open') Create a new pane running Claude
      in the repo referenced by <key> in workspace.json.

  cc-cockpit mark-ended <sid-prefix | all-non-ended>
      Append a synthetic SessionEnd for stale sessions (no SessionEnd emitted,
      e.g. after a terminal crash). Takes a session_id prefix or 'all-non-ended'.

  cc-cockpit hook <EventName>
      Internal — invoked from ~/.claude/settings.json hooks. Reads payload
      from stdin and appends an event to events.jsonl.

  cc-cockpit --version
EOF
  ;;
  *) die "unknown subcommand '$1' (try: cc-cockpit --help)" ;;
esac
