#!/bin/bash
# cc-cockpit — v1 MVP (single-binary dispatch)
#
# Subcommands:
#   install                — install PATH symlink and Claude Code hooks
#   init                   — create .cc-cockpit/workspace.json
#   doctor                 — validate local install and workspace health
#   open                   — detect workspace.json, init state, launch Zellij
#   start REPO TASK...     — create new pane running Claude in repo X
#   spawn --repo X --task  — compatibility spelling for start
#   hook <EventName>       — internal: read stdin payload, append event
#   --version              — print version

set -u
VERSION="0.1.0-mvp"

# Resolve install root (dir containing reduce-state.sh, dashboard.sh, layouts/).
# Follows symlinks so ~/.local/bin/cc-cockpit -> ~/cc-cockpit-dev/.cc-cockpit/bin/cc-cockpit works.
__bin_real="$(readlink -f "${BASH_SOURCE[0]}")"
CC_COCKPIT_INSTALL_HOME="$(dirname "$(dirname "$__bin_real")")"

die() { echo "cc-cockpit: $*" >&2; exit 2; }

valid_slug() {
  local s="$1"
  [[ "$s" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]
}

slug_from_path() {
  local base s
  base="$(basename "$(realpath -m -- "$1")")"
  s="$(printf '%s' "$base" | tr -c 'a-zA-Z0-9._-' '-')"
  while [ -n "$s" ] && [[ ! "${s:0:1}" =~ [a-zA-Z0-9] ]]; do
    s="${s:1}"
  done
  [ -n "$s" ] || s="workspace"
  printf '%s\n' "$s"
}

# ---------- workspace discovery ----------
find_workspace() {
  local d="$PWD"
  while [ "$d" != "/" ]; do
    if [ -f "$d/.cc-cockpit/workspace.json" ]; then
      echo "$d"
      return 0
    fi
    d="$(dirname "$d")"
  done
  return 1
}

install_claude_hooks() {
  local settings="$1"
  local bin_link="$2"
  local settings_dir tmp input backup_ts

  settings_dir="$(dirname "$settings")"
  mkdir -p "$settings_dir" || die "install: cannot create settings dir '$settings_dir'"

  if [ -f "$settings" ]; then
    jq -e 'type == "object" and ((has("hooks") | not) or (.hooks | type == "object"))' "$settings" >/dev/null 2>&1 \
      || die "install: existing Claude settings must be a valid JSON object with object-valued hooks: $settings"
    input="$settings"
  else
    input="$(mktemp "$settings_dir/settings.empty.XXXXXX")" \
      || die "install: cannot create temporary settings file"
    printf '{}\n' > "$input"
  fi

  tmp="$(mktemp "$settings.tmp.XXXXXX")" \
    || die "install: cannot create temporary settings file"
  jq --arg bin "$bin_link" '
    def entry($event):
      if $event == "Notification" then
        {
          matcher: "idle_prompt|permission_prompt",
          hooks: [{type: "command", command: ($bin + " hook " + $event)}]
        }
      else
        {
          hooks: [{type: "command", command: ($bin + " hook " + $event)}]
        }
      end;
    def has_cockpit_hook:
      any(.hooks[]?; ((.command // "") | contains("cc-cockpit hook ")));
    def upsert($event):
      .hooks[$event] = (((.hooks[$event] // []) | map(select(has_cockpit_hook | not))) + [entry($event)]);
    .hooks = (.hooks // {})
    | upsert("SessionStart")
    | upsert("UserPromptSubmit")
    | upsert("PermissionRequest")
    | upsert("Notification")
    | upsert("PostToolUse")
    | upsert("Stop")
    | upsert("SessionEnd")
  ' "$input" > "$tmp" \
    || die "install: failed to merge Claude hooks into settings"

  if [ -f "$settings" ] && cmp -s "$tmp" "$settings"; then
    rm -f "$tmp"
    [ "$input" = "$settings" ] || rm -f "$input"
    return 0
  fi

  if [ -f "$settings" ]; then
    backup_ts="$(date +%Y%m%d-%H%M%S)"
    cp "$settings" "$settings.bak-$backup_ts" \
      || die "install: cannot back up '$settings'"
  fi

  mv "$tmp" "$settings" || die "install: cannot write '$settings'"
  [ "$input" = "$settings" ] || rm -f "$input"
}

# ============================================================
# cmd: install
# ============================================================
cmd_install() {
  local bin_dir="${CC_COCKPIT_BIN_DIR:-$HOME/.local/bin}"
  local settings="${CLAUDE_SETTINGS_PATH:-$HOME/.claude/settings.json}"
  local install_bin=1 install_hooks=1

  while [ $# -gt 0 ]; do
    case "$1" in
      --bin-dir)
        [ $# -ge 2 ] || die "install: --bin-dir requires a value"
        bin_dir="$2"; shift 2 ;;
      --settings)
        [ $# -ge 2 ] || die "install: --settings requires a value"
        settings="$2"; shift 2 ;;
      --no-bin) install_bin=0; shift ;;
      --no-hooks) install_hooks=0; shift ;;
      *) die "install: unknown flag '$1'" ;;
    esac
  done

  command -v jq >/dev/null || die "install: jq not found on PATH"

  local bin_link="$bin_dir/cc-cockpit"
  if [ "$install_bin" -eq 1 ]; then
    mkdir -p "$bin_dir" || die "install: cannot create bin dir '$bin_dir'"
    ln -sf "$__bin_real" "$bin_link" || die "install: cannot symlink '$bin_link'"
    echo "install: installed $bin_link -> $__bin_real"
  fi

  if [ "$install_hooks" -eq 1 ]; then
    install_claude_hooks "$settings" "$bin_link"
    echo "install: installed Claude Code hooks in $settings"
  fi

  command -v zellij >/dev/null || echo "install: warning: zellij not found on PATH" >&2
  command -v claude >/dev/null || echo "install: warning: claude not found on PATH" >&2
  echo "install: done"
}

add_repo_spec() {
  local root="$1" key="$2" path="$3"
  local root_real abs rel existing

  valid_slug "$key" || die "init: invalid repo label '$key' (must match ^[a-zA-Z0-9][a-zA-Z0-9._-]*$)"
  for existing in "${INIT_REPO_KEYS[@]}"; do
    [ "$existing" != "$key" ] || die "init: duplicate repo label '$key'; pass explicit labels like api=packages/api"
  done

  root_real="$(realpath -- "$root")" || die "init: cannot canonicalize workspace root"
  if [[ "$path" = /* ]]; then
    abs="$(realpath -m -- "$path")"
  else
    abs="$(realpath -m -- "$root/$path")"
  fi
  case "$abs/" in
    "$root_real"/?*/) : ;;
    *) die "init: repo '$key' resolves outside workspace root: $path" ;;
  esac
  [ -d "$abs" ] || die "init: repo dir does not exist: $path"
  git -C "$abs" rev-parse --git-dir >/dev/null 2>&1 \
    || die "init: '$path' is not a git repo"

  rel="$(realpath --relative-to="$root_real" "$abs")" \
    || die "init: cannot compute relative path for '$path'"
  INIT_REPO_KEYS+=("$key")
  INIT_REPO_PATHS+=("$rel")
}

# ============================================================
# cmd: init
# ============================================================
cmd_init() {
  local name="" force=0 root="$PWD"
  local specs=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --name)
        [ $# -ge 2 ] || die "init: --name requires a value"
        name="$2"; shift 2 ;;
      --force) force=1; shift ;;
      -*) die "init: unknown flag '$1'" ;;
      *) specs+=("$1"); shift ;;
    esac
  done

  [ -n "$name" ] || name="$(slug_from_path "$root")"
  valid_slug "$name" || die "init: invalid workspace name '$name' (must match ^[a-zA-Z0-9][a-zA-Z0-9._-]*$)"

  INIT_REPO_KEYS=()
  INIT_REPO_PATHS=()

  if [ "${#specs[@]}" -gt 0 ]; then
    local spec key path
    for spec in "${specs[@]}"; do
      if [[ "$spec" == *=* ]]; then
        key="${spec%%=*}"
        path="${spec#*=}"
      else
        path="$spec"
        key="$(slug_from_path "$path")"
      fi
      [ -n "$path" ] || die "init: empty path in repo spec '$spec'"
      add_repo_spec "$root" "$key" "$path"
    done
  else
    local gitdir repo_dir key
    while IFS= read -r gitdir; do
      repo_dir="$(dirname "$gitdir")"
      key="$(slug_from_path "$repo_dir")"
      add_repo_spec "$root" "$key" "$repo_dir"
    done < <(find "$root" -mindepth 2 -maxdepth 4 -type d -name .git -prune -print | sort)
  fi

  [ "${#INIT_REPO_KEYS[@]}" -gt 0 ] \
    || die "init: no child git repos found. Run from a workspace parent or pass repo specs like api=packages/api"

  local ws_dir="$root/.cc-cockpit"
  local ws_json="$ws_dir/workspace.json"
  if [ -e "$ws_json" ] && [ "$force" -ne 1 ]; then
    die "init: workspace already exists at $ws_json (use --force to rewrite)"
  fi

  mkdir -p "$ws_dir" || die "init: cannot create '$ws_dir'"

  local repos_json tmp i
  repos_json="$(
    for i in "${!INIT_REPO_KEYS[@]}"; do
      printf '%s\t%s\n' "${INIT_REPO_KEYS[$i]}" "${INIT_REPO_PATHS[$i]}"
    done | jq -Rn '[inputs | split("\t") | {key:.[0], value:.[1]}] | from_entries'
  )" || die "init: cannot build repo JSON"

  tmp="$ws_json.tmp.$$"
  jq -n --arg n "$name" --argjson r "$repos_json" '{name:$n, repos:$r}' > "$tmp" \
    || die "init: cannot write workspace JSON"
  mv "$tmp" "$ws_json" || die "init: cannot replace '$ws_json'"

  echo "workspace: $name"
  echo "config: $ws_json"
  echo
  echo "repos:"
  for i in "${!INIT_REPO_KEYS[@]}"; do
    printf '  %-16s %s\n' "${INIT_REPO_KEYS[$i]}" "${INIT_REPO_PATHS[$i]}"
  done
  echo
  echo "next:"
  echo "  cc-cockpit open"
  echo "  cc-cockpit start ${INIT_REPO_KEYS[0]} <task>"
}

doctor_ok() {
  echo "ok: $*"
}

doctor_fail() {
  echo "fail: $*"
  DOCTOR_ISSUES=$((DOCTOR_ISSUES+1))
}

# ============================================================
# cmd: doctor
# ============================================================
cmd_doctor() {
  DOCTOR_ISSUES=0

  local found settings count matcher_count ws ws_json name ws_root key rel abs

  if found="$(command -v jq 2>/dev/null)"; then
    doctor_ok "jq found: $(jq --version 2>/dev/null || echo "$found")"
  else
    doctor_fail "jq not found on PATH"
  fi

  if found="$(command -v zellij 2>/dev/null)"; then
    doctor_ok "zellij found: $found"
  else
    doctor_fail "zellij not found on PATH"
  fi

  if found="$(command -v claude 2>/dev/null)"; then
    doctor_ok "claude found: $found"
  else
    doctor_fail "claude not found on PATH"
  fi

  if found="$(command -v cc-cockpit 2>/dev/null)"; then
    doctor_ok "cc-cockpit found: $found"
  else
    doctor_fail "cc-cockpit not found on PATH (run ./install from the source checkout)"
  fi

  settings="${CLAUDE_SETTINGS_PATH:-$HOME/.claude/settings.json}"
  if [ ! -f "$settings" ]; then
    doctor_fail "Claude settings not found: $settings (run cc-cockpit install)"
  elif ! jq -e 'type == "object" and ((has("hooks") | not) or (.hooks | type == "object"))' "$settings" >/dev/null 2>&1; then
    doctor_fail "Claude settings is not a valid JSON object with object-valued hooks: $settings"
  else
    local event
    for event in SessionStart UserPromptSubmit PermissionRequest Notification PostToolUse Stop SessionEnd; do
      count="$(jq -r --arg event "$event" \
        '[.hooks[$event][]? | .hooks[]? | select((.command // "") | contains("cc-cockpit hook " + $event))] | length' \
        "$settings" 2>/dev/null || echo 0)"
      if [ "${count:-0}" -gt 0 ]; then
        doctor_ok "Claude hook installed: $event"
      else
        doctor_fail "Claude hook missing: $event (run cc-cockpit install)"
      fi
    done

    matcher_count="$(jq -r '
      [.hooks.Notification[]?
       | select((.matcher // "") == "idle_prompt|permission_prompt")
       | .hooks[]?
       | select((.command // "") | contains("cc-cockpit hook Notification"))]
      | length
    ' "$settings" 2>/dev/null || echo 0)"
    if [ "${matcher_count:-0}" -gt 0 ]; then
      doctor_ok "Notification hook matcher is idle_prompt|permission_prompt"
    else
      doctor_fail "Notification hook matcher missing idle_prompt|permission_prompt"
    fi
  fi

  if ! ws="$(find_workspace)"; then
    doctor_fail "workspace not initialized (run cc-cockpit init from the workspace parent)"
  else
    ws_root="$(realpath -- "$ws")" || ws_root="$ws"
    ws_json="$ws/.cc-cockpit/workspace.json"
    if ! jq -e 'type == "object" and (.name | type == "string") and (.repos | type == "object")' "$ws_json" >/dev/null 2>&1; then
      doctor_fail "workspace.json must be an object with string .name and object .repos: $ws_json"
    else
      name="$(jq -r '.name' "$ws_json")"
      if valid_slug "$name"; then
        doctor_ok "workspace: $name ($ws_root)"
      else
        doctor_fail "invalid workspace name '$name'"
      fi

      if [ "$(jq '.repos | length' "$ws_json")" -eq 0 ]; then
        doctor_fail "workspace has no repos configured"
      fi

      while IFS=$'\t' read -r key rel; do
        [ -n "$key" ] || continue
        if ! valid_slug "$key"; then
          doctor_fail "invalid repo label '$key'"
          continue
        fi
        if [[ "$rel" = /* ]]; then
          abs="$(realpath -m -- "$rel")"
        else
          abs="$(realpath -m -- "$ws_root/$rel")"
        fi
        case "$abs/" in
          "$ws_root"/?*/) ;;
          *)
            doctor_fail "repo '$key' resolves outside workspace root: $rel"
            continue ;;
        esac
        if [ ! -d "$abs" ]; then
          doctor_fail "repo '$key' dir does not exist: $rel"
        elif ! git -C "$abs" rev-parse --git-dir >/dev/null 2>&1; then
          doctor_fail "repo '$key' is not a git repo: $rel"
        else
          doctor_ok "repo '$key': $rel"
        fi
      done < <(jq -r '.repos | to_entries[] | [.key, .value] | @tsv' "$ws_json")
    fi
  fi

  if [ "$DOCTOR_ISSUES" -eq 0 ]; then
    echo "doctor: all checks passed"
    return 0
  fi

  echo "doctor: $DOCTOR_ISSUES issue(s) found"
  return 1
}

# ---------- shared: append event under flock ----------
# $1 = event JSON (without seq / wall_clock_iso8601).
#
# Seq-gap note: the counter is bumped BEFORE the log append. If the log write
# fails (ENOSPC, ENOENT during race, etc.) the counter is permanently ahead
# and a gap in seq values is left. The reducer tolerates gaps (sort_by keeps
# order regardless), so this is a silent event-loss failure mode rather than
# a corruption one. A future hardening could use a single transactional write
# (event carries its own seq; counter updates from the event tail). v0.1: OK.
append_event() {
  local ev="$1"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || return 0
  mkdir -p "$COCKPIT_STATE_HOME"
  local lock="$COCKPIT_STATE_HOME/events.lock"
  local counter="$COCKPIT_STATE_HOME/seq.counter"
  local log="$COCKPIT_STATE_HOME/events.jsonl"
  (
    flock -x 9
    local seq=$(( $(cat "$counter" 2>/dev/null || echo 0) + 1 ))
    echo "$seq" > "$counter"
    local ts
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -c \
      --argjson seq "$seq" \
      --arg ts "$ts" \
      '. + {seq: $seq, wall_clock_iso8601: $ts}' \
      <<< "$ev" >> "$log"
  ) 9>"$lock"
}

# ============================================================
# cmd: open
# ============================================================
cmd_open() {
  local ws
  ws="$(find_workspace)" || die "Not in a cc-cockpit workspace. Run 'cc-cockpit init' from the workspace parent first."

  # Canonicalize workspace root — state binds to this exact path.
  local ws_canonical
  ws_canonical="$(realpath -- "$ws")" || die "cannot canonicalize workspace path: $ws"

  local ws_json="$ws/.cc-cockpit/workspace.json"
  jq -e 'type == "object"' "$ws_json" >/dev/null 2>&1 \
    || die "workspace.json must be a valid JSON object"

  local name
  name="$(jq -r '.name // empty' "$ws_json")"
  [ -n "$name" ] && [ "$name" != "null" ] || die "workspace.json missing 'name'"

  # Validate name as a safe slug — no path components, no traversal, must start alnum.
  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    die "invalid workspace name '$name' — must match ^[a-zA-Z0-9][a-zA-Z0-9._-]*\$ (no slashes, no '..')"
  fi

  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}/cc-cockpit/$name"
  mkdir -p "$state_home" \
    || die "cannot create state dir '$state_home' (permission denied or parent not writable)"
  [ -w "$state_home" ] \
    || die "state dir '$state_home' is not writable"

  # Sanity-check the install tree — if cc-cockpit was copied (not symlinked)
  # onto PATH without its siblings, CC_COCKPIT_INSTALL_HOME resolves to a dir
  # missing reduce-state.sh et al., and the dashboard would fail with an
  # unhelpful 'no such file' later. Fail loud and early.
  for f in reduce-state.sh render.sh dashboard.sh layouts/initial.kdl; do
    [ -e "$CC_COCKPIT_INSTALL_HOME/$f" ] \
      || die "broken install: missing '$CC_COCKPIT_INSTALL_HOME/$f'. Symlink the binary from a full source tree instead of copying it."
  done

  # Bind name ↔ canonical root under an init lock. The check-and-write of
  # workspace_root, seq.counter, and events.jsonl must be atomic — otherwise two
  # unrelated directories with the same 'name' opening concurrently could both
  # observe "no binding" and initialize the same state dir.
  {
    flock -x 200
    if [ -f "$state_home/workspace_root" ]; then
      local persisted
      persisted="$(cat "$state_home/workspace_root")"
      if [ "$persisted" != "$ws_canonical" ]; then
        die "workspace name '$name' is already bound to '$persisted' (current is '$ws_canonical').
    Rename the workspace (change 'name' in .cc-cockpit/workspace.json) or remove the stale
    state dir: rm -rf '$state_home'"
      fi
    else
      echo "$ws_canonical" > "$state_home/workspace_root"
    fi
    [ -f "$state_home/seq.counter" ] || echo 0 > "$state_home/seq.counter"
    [ -f "$state_home/events.jsonl" ] || touch "$state_home/events.jsonl"
  } 200>"$state_home/init.lock"

  command -v zellij >/dev/null || die "zellij not found on PATH"

  # Live-instance lock. Per design, only one cockpit may run against a workspace
  # at a time — concurrent cockpits would race on current.json.tmp, last_bell_seq,
  # and events.snapshot.jsonl. We take a non-blocking exclusive flock on fd 201
  # and hold it through `exec zellij`: bash does not set FD_CLOEXEC on
  # redirect-opened fds, so the lock persists until the zellij process exits.
  #
  # PID hint lives in a SEPARATE file (cockpit.live.pid), written only after the
  # lock is acquired. A would-be second caller reads that file BEFORE opening the
  # lockfile so the PID hint survives even though opening the lockfile truncates.
  local pid_file="$state_home/cockpit.live.pid"
  local lock_file="$state_home/cockpit.live.lock"
  local existing_holder=""
  [ -s "$pid_file" ] && existing_holder=" (pid $(cat "$pid_file" 2>/dev/null || echo ?))"

  exec 201>"$lock_file"
  if ! flock -n -x 201; then
    die "a cockpit is already running for workspace '$name'$existing_holder.
    Lockfile: $lock_file
    If you believe the holder is gone (stale lock): rm -f '$lock_file' '$pid_file'"
  fi
  # Record the eventual zellij PID. ($$ doesn't change through exec.)
  echo "$$" > "$pid_file"

  export CC_COCKPIT_HOME="$CC_COCKPIT_INSTALL_HOME"
  export COCKPIT_STATE_HOME="$state_home"
  export COCKPIT_WORKSPACE_NAME="$name"
  export CC_COCKPIT_WORKSPACE_ROOT="$ws_canonical"

  echo "cc-cockpit: workspace=$name  state=$state_home  home=$CC_COCKPIT_HOME"
  exec zellij --layout "$CC_COCKPIT_HOME/layouts/initial.kdl"
}

# ============================================================
# cmd: spawn
# ============================================================
cmd_spawn() {
  local repo="" task="" related=""
  local cmd_name="${CC_COCKPIT_CMD_NAME:-spawn}"
  local positional=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo|--task|--related)
        local flag="$1"
        if [ $# -lt 2 ] || [[ "$2" == --* ]]; then
          die "$cmd_name: $flag requires a value"
        fi
        case "$flag" in
          --repo)    repo="$2" ;;
          --task)    task="$2" ;;
          --related) related="$2" ;;
        esac
        shift 2
        ;;
      --)
        shift
        positional+=("$@")
        break
        ;;
      -*)
        die "$cmd_name: unknown flag '$1'"
        ;;
      *)
        positional+=("$1")
        shift
        ;;
    esac
  done
  if [ "${#positional[@]}" -gt 0 ]; then
    local task_start=0
    if [ -z "$repo" ]; then
      repo="${positional[0]}"
      task_start=1
    fi
    if [ "$task_start" -lt "${#positional[@]}" ]; then
      if [ -n "$task" ]; then
        die "$cmd_name: unexpected positional task '${positional[$task_start]}'"
      fi
      task="${positional[*]:$task_start}"
    fi
  fi

  [ -n "$repo" ] || die "$cmd_name: repo required (usage: cc-cockpit $cmd_name <repo> <task...>)"
  [ -n "$task" ] || die "$cmd_name: task required (usage: cc-cockpit $cmd_name <repo> <task...>)"
  [ -n "${ZELLIJ:-}" ] || die "$cmd_name: must be run inside a Zellij session (launched by 'cc-cockpit open')"
  [ -n "${CC_COCKPIT_HOME:-}" ] || die "$cmd_name: CC_COCKPIT_HOME not set — run 'cc-cockpit open' first"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || die "$cmd_name: COCKPIT_STATE_HOME not set"
  [ -n "${CC_COCKPIT_WORKSPACE_ROOT:-}" ] || die "$cmd_name: CC_COCKPIT_WORKSPACE_ROOT not set"

  local ws_json="$CC_COCKPIT_WORKSPACE_ROOT/.cc-cockpit/workspace.json"
  # Validate shape before indexing — a malformed .repos would error out of
  # jq with a confusing message.
  jq -e '.repos | type == "object"' "$ws_json" >/dev/null 2>&1 \
    || die "$cmd_name: workspace.json .repos must be an object { \"<label>\": \"<path>\", ... }"
  local rel
  rel="$(jq -r --arg k "$repo" '.repos[$k] // empty' "$ws_json")"
  if [ -z "$rel" ]; then
    local valid
    valid="$(jq -r '.repos | keys | join(", ")' "$ws_json")"
    die "$cmd_name: unknown repo '$repo'. Valid: $valid"
  fi

  # Resolve + enforce containment. workspace.json values may be ../foo, absolute paths, or
  # symlinks — we canonicalize and require strict descendant of the canonical workspace root.
  local ws_root abs
  ws_root="$(realpath -- "$CC_COCKPIT_WORKSPACE_ROOT")" || die "$cmd_name: cannot canonicalize workspace root"
  abs="$(realpath -m -- "$CC_COCKPIT_WORKSPACE_ROOT/$rel")"
  case "$abs/" in
    "$ws_root"/?*/) : ;;
    *) die "$cmd_name: repo '$repo' resolves outside workspace root.
    resolved: $abs
    workspace: $ws_root" ;;
  esac
  [ -d "$abs" ] || die "$cmd_name: repo dir does not exist: $abs"

  # Enforce "child repo is a real git repo" invariant.
  if ! git -C "$abs" rev-parse --git-dir >/dev/null 2>&1; then
    die "$cmd_name: '$abs' is not a git repo. cc-cockpit only spawns in real child repos (run 'git init' there if you meant to)."
  fi

  command -v claude >/dev/null || die "$cmd_name: 'claude' not found on PATH"

  local pane_name="${repo}: ${task}"
  # Truncate pane name to something reasonable
  pane_name="${pane_name:0:60}"

  zellij action new-pane --cwd "$abs" --name "$pane_name" -- \
    env \
      COCKPIT_SESSION_ACTIVE=1 \
      COCKPIT_STATE_HOME="$COCKPIT_STATE_HOME" \
      CC_COCKPIT_HOME="$CC_COCKPIT_HOME" \
      COCKPIT_WORKSPACE_NAME="$COCKPIT_WORKSPACE_NAME" \
      COCKPIT_PRIMARY_REPO="$repo" \
      COCKPIT_DECLARED_RELATED_REPOS="$related" \
      COCKPIT_TASK_NAME="$task" \
      claude
}

# ============================================================
# cmd: mark-ended (operator utility — dismiss stale sessions)
# ============================================================
cmd_mark_ended() {
  local prefix="" yes_flag=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y) yes_flag=1; shift ;;
      -*) die "mark-ended: unknown flag '$1'" ;;
      *)
        [ -z "$prefix" ] || die "mark-ended: only one positional argument expected"
        prefix="$1"; shift ;;
    esac
  done
  [ -n "$prefix" ] || die "mark-ended: need <session_id-prefix> (or 'all-non-ended') [--yes]"
  [ -n "${COCKPIT_STATE_HOME:-}" ] || die "mark-ended: COCKPIT_STATE_HOME not set (run inside 'cc-cockpit open')"

  local log="$COCKPIT_STATE_HOME/events.jsonl"
  [ -f "$log" ] || die "no events.jsonl in $COCKPIT_STATE_HOME"

  # Collect session_ids whose latest status is not ended
  local current="$COCKPIT_STATE_HOME/current.json"
  [ -f "$current" ] || die "no current.json yet (wait for dashboard tick)"

  local targets
  if [ "$prefix" = "all-non-ended" ]; then
    targets="$(jq -r '(.sessions // {}) | to_entries[] | select(.value.status != "ended") | .key' "$current")"
  else
    targets="$(jq -r --arg p "$prefix" \
      '(.sessions // {}) | to_entries[] | select(.value.status != "ended" and (.key | startswith($p))) | .key' \
      "$current")"
  fi

  if [ -z "$targets" ]; then
    echo "mark-ended: no matching non-ended sessions for '$prefix'"
    return 0
  fi

  local count
  count="$(printf '%s\n' "$targets" | grep -c . || true)"

  # Defensive: require --yes when dismissing more than one session, since
  # mark-ended acts on a possibly-stale snapshot. A synthetic SessionEnd is
  # revivable (any later event from the live session will un-dismiss), but
  # noisy confirmation is still cheaper than silent batch-kill.
  if [ "$count" -gt 1 ] && [ "$yes_flag" -ne 1 ]; then
    echo "mark-ended: would dismiss $count session(s):" >&2
    while IFS= read -r sid; do [ -n "$sid" ] && printf '  - %s\n' "$sid" >&2; done <<< "$targets"
    die "re-run with --yes to confirm (or give a more specific prefix)"
  fi

  local dismissed=0
  while IFS= read -r sid; do
    [ -n "$sid" ] || continue
    local ev
    ev="$(jq -n --arg sid "$sid" --arg et "SessionEnd" \
      '{event_type:$et, session_id:$sid, payload:{synthetic:true, reason:"operator-dismissed"}}')"
    append_event "$ev"
    echo "  dismissed: $sid"
    dismissed=$((dismissed+1))
  done <<< "$targets"
  echo "mark-ended: $dismissed session(s) dismissed (any later event from a live session will un-dismiss)."
}

# ============================================================
# cmd: hook
# ============================================================
cmd_hook() {
  local event="${1:-}"
  [ -n "$event" ] || exit 0

  # Guard: silent no-op outside a cockpit-spawned session
  [ "${COCKPIT_SESSION_ACTIVE:-}" = "1" ] || exit 0
  [ -n "${COCKPIT_STATE_HOME:-}" ] || exit 0
  mkdir -p "$COCKPIT_STATE_HOME" 2>/dev/null || exit 0

  # Hooks must be silent on the Claude Code side: any stderr from jq lands in
  # the claude pane as noise. Every jq call here redirects stderr; any failure
  # causes an exit 0 (silent no-op), protecting the operator from a malformed
  # payload turning the pane into an error stream.
  local payload sid
  payload="$(cat)"
  sid="$(jq -r '.session_id // empty' <<< "$payload" 2>/dev/null)"
  [ -n "$sid" ] || exit 0

  local ev=''
  case "$event" in
    SessionStart)
      ev="$(jq -n 2>/dev/null \
        --arg sid "$sid" \
        --arg et  "SessionStart" \
        --arg repo "${COCKPIT_PRIMARY_REPO:-}" \
        --arg related "${COCKPIT_DECLARED_RELATED_REPOS:-}" \
        --arg task "${COCKPIT_TASK_NAME:-}" \
        --arg pane "${ZELLIJ_PANE_ID:-}" \
        --argjson payload "$payload" \
        '{
          event_type: $et,
          session_id: $sid,
          payload: {
            primary_repo: $repo,
            declared_related_repos: ($related | split(",") | map(select(length>0))),
            task_name: $task,
            cwd: ($payload.cwd // null),
            zellij_pane_id: (if $pane=="" then null else $pane end),
            source: ($payload.source // null),
            model: ($payload.model // null)
          }
        }')"
      ;;
    UserPromptSubmit)
      local preview
      preview="$(jq -r '.prompt // ""' <<< "$payload" 2>/dev/null | tr '\n' ' ' | cut -c1-80)"
      ev="$(jq -n 2>/dev/null \
        --arg sid "$sid" --arg et "UserPromptSubmit" --arg p "$preview" \
        '{event_type:$et, session_id:$sid, payload:{prompt_preview:$p}}')"
      ;;
    PermissionRequest)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "PermissionRequest" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    Notification)
      local ntype
      ntype="$(jq -r '.notification_type // ""' <<< "$payload" 2>/dev/null)"
      # Only admit idle_prompt / permission_prompt — these genuinely require operator attention
      case "$ntype" in
        idle_prompt|permission_prompt) ;;
        *) exit 0 ;;
      esac
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "Notification" --arg nt "$ntype" \
        '{event_type:$et, session_id:$sid, payload:{notification_type:$nt}}')"
      ;;
    PostToolUse)
      local tool
      tool="$(jq -r '.tool_name // ""' <<< "$payload" 2>/dev/null)"
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "PostToolUse" --arg t "$tool" \
        '{event_type:$et, session_id:$sid, payload:{tool_name:$t, success:true}}')"
      ;;
    Stop)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "Stop" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    SessionEnd)
      ev="$(jq -n 2>/dev/null --arg sid "$sid" --arg et "SessionEnd" \
        '{event_type:$et, session_id:$sid, payload:{}}')"
      ;;
    *) exit 0 ;;
  esac

  # If jq failed to produce an event (empty), silently drop this hook
  [ -n "$ev" ] || exit 0
  append_event "$ev" 2>/dev/null || exit 0
}

# ============================================================
# dispatch
# ============================================================
case "${1:-}" in
  --version|-v) echo "cc-cockpit $VERSION" ;;
  install)      shift; cmd_install "$@" ;;
  setup)        shift; cmd_install "$@" ;;
  init)         shift; cmd_init "$@" ;;
  doctor)       shift; cmd_doctor "$@" ;;
  open)         shift; cmd_open "$@" ;;
  start)        shift; CC_COCKPIT_CMD_NAME=start cmd_spawn "$@" ;;
  spawn)        shift; CC_COCKPIT_CMD_NAME=spawn cmd_spawn "$@" ;;
  mark-ended)   shift; cmd_mark_ended "$@" ;;
  hook)         shift; cmd_hook "$@" ;;
  help|--help|"") cat <<EOF
cc-cockpit $VERSION

Usage:
  cc-cockpit install [--bin-dir DIR] [--settings FILE] [--no-bin] [--no-hooks]
      Install the cc-cockpit command on PATH and install Claude Code hooks.

  cc-cockpit init [--name NAME] [--force] [repo=path ...]
      Create .cc-cockpit/workspace.json in the current directory. With no repo
      specs, auto-discovers child git repos below the current directory.

  cc-cockpit doctor
      Check install, hooks, prerequisites, and workspace repo health.

  cc-cockpit open
      Open the cockpit for the workspace containing your cwd.

  cc-cockpit start <repo> <task...> [--related A,B]
      (run from a Zellij pane inside 'open') Create a new pane running Claude
      in the repo referenced by <repo> in workspace.json.

  cc-cockpit mark-ended <sid-prefix | all-non-ended>
      Append a synthetic SessionEnd for stale sessions (no SessionEnd emitted,
      e.g. after a terminal crash). Takes a session_id prefix or 'all-non-ended'.

  cc-cockpit --version
EOF
  ;;
  *) die "unknown subcommand '$1' (try: cc-cockpit --help)" ;;
esac
